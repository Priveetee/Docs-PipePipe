flowchart TB
  subgraph CHECKS["1. Start with the PipePipe version"]
    direction TB
    START["Start a YouTube video"] --> VERSION{"PipePipe 5.2.4-beta<br/>or newer?"}
    VERSION -- "No" --> UPDATE["Update PipePipe first"]
    VERSION -- "Yes" --> PROVIDER{"Android exposes an active<br/>WebView provider?"}
    PROVIDER -- "No" --> ERROR["WebView unavailable<br/>Check the active provider"]
    PROVIDER -- "Yes" --> COMPAT["Compatibility runtime<br/>supports old WebView JavaScript"]
  end

  COMPAT --> DELIVERY

  subgraph DELIVERY["2. Local YouTube playback path"]
    direction TB
    EJS["ES5-compatible EJS decoder"] --> BOT["WebView runs BotGuard"]
    BOT --> TOKEN["Session and video tokens"]
    TOKEN --> SABR["SABR audio and video"]
    SABR --> PLAY["Playback"]
  end

  style CHECKS fill:transparent
  style DELIVERY fill:transparent
